# rayobrowse Configuration
# Copy this file to .env and customize:
#   cp .env.example .env

# ── Terms of Service ─────────────────────────────────────────────────────────
# Required. Set to "true" to confirm you have read and agree to the terms:
#   README:  https://github.com/rayobyte-data/rayobrowse/blob/main/README.md
#   LICENSE: https://github.com/rayobyte-data/rayobrowse/blob/main/LICENSE
# The daemon will refuse all create_browser() calls until this is set.
# After changing, recreate the container: docker compose up -d
STEALTH_BROWSER_ACCEPT_TERMS=false

# ── Authentication ────────────────────────────────────────────────────────────
# API key for paid plans (leave empty for free tier — 1 concurrent browser)
STEALTH_BROWSER_API_KEY=

# ── noVNC viewer ──────────────────────────────────────────────────────────────
# true  — watch live browser sessions at http://localhost:6080/vnc.html (default)
# false — viewer disabled, slightly lower CPU overhead
STEALTH_BROWSER_NOVNC=true

# ── Remote / Cloud Mode ──────────────────────────────────────────────────────
# Set to "remote" to expose the daemon publicly (e.g. for cloud browser platforms).
# In remote mode:
#   - Management endpoints (POST /browser, GET /browsers, DELETE /browser)
#     require the API key via X-API-Key header or Authorization: Bearer header
#   - Health and CDP endpoints remain open (browser IDs act as auth tokens)
#   - The daemon auto-detects its public IP for ws_endpoint URLs
# Default: local
# STEALTH_BROWSER_DAEMON_MODE=local

# Public URL override for remote mode (optional).
# Used as the base for ws_endpoint URLs returned by POST /browser.
# If not set, the daemon auto-detects the server's public IP.
# Examples: http://browser.example.com  or  http://203.0.113.42
# STEALTH_BROWSER_PUBLIC_URL=

# Host port for remote mode (optional).
# In docker-compose.yml, set RAYOBROWSE_PORT to map a different host port.
# Default: 9222 (local mode), 80 for remote (set RAYOBROWSE_PORT=80 in .env)
# RAYOBROWSE_PORT=80
